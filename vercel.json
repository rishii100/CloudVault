{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/dashboard",
            "destination": "/api/index.js"
        },
        {
            "source": "/review/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*\\.ejs$|.*\\.js$|.*\\.css$|.*\\.png$|.*\\.svg$|.*\\.ico$|.*\\.txt$)",
            "destination": "/public/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ]
}